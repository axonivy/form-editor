{
  "private": true,
  "name": "@axonivy/form-editor-root",
  "engines": {
    "node": ">=20.19.0"
  },
  "volta": {
    "node": "24.14.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "check": "pnpm run type && (pnpm run lint:ci || true) && pnpm run test:ci && pnpm run i18n:ci",
    "clean": "pnpm run -r clean",
    "build": "tsc --build",
    "package": "pnpm run -r package",
    "build:clean": "pnpm run -r build:clean",
    "type": "pnpm run -r type",
    "lint": "eslint",
    "lint:ci": "eslint -o eslint.xml -f checkstyle",
    "lint:fix": "eslint --fix",
    "lint:inspect": "eslint --inspect-config",
    "i18n": "pnpm run -r i18n",
    "i18n:ci": "pnpm run -r i18n:ci",
    "protocol": "pnpm run --filter @axonivy/form-editor-protocol",
    "dev": "pnpm run --filter @axonivy/form-editor-standalone dev",
    "test": "pnpm run --filter @axonivy/form-editor test",
    "test:ci": "pnpm run -r test:ci",
    "webtest": "pnpm run -r webtest --",
    "update:axonivy:next": "npx --yes npm-check-updates @axonivy* -w -c 0 -t semver -u",
    "raise:version": "lerna version --no-git-tag-version --no-push --ignore-scripts --exact --yes",
    "publish:next": "lerna publish --exact --canary --preid next --tag-version-prefix beta --pre-dist-tag next --no-git-tag-version --no-push --ignore-scripts --yes"
  },
  "devDependencies": {
    "@axonivy/eslint-config": "~12.0.15-next.750.0ac5589",
    "@lerna-lite/cli": "^4.11.2",
    "@lerna-lite/publish": "^4.11.2",
    "@lerna-lite/version": "^4.11.2",
    "@types/node": "^24.10.0",
    "eslint-plugin-i18next": "^6.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
